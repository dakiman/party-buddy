# Used by Vite at build/dev time. Both vars are concatenated as `VITE_API_URL + VITE_API_PREFIX` to form the axios baseURL.

# Local dev (uncomment for local dev — copy this file to .env.development.local)
# VITE_API_URL=http://localhost:8080
# VITE_API_PREFIX=

# Production (same-origin reverse-proxied — copy this file to .env.production.local)
# VITE_API_URL=
# VITE_API_PREFIX=/api
